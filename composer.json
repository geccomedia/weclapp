{
    "name": "geccomedia/weclapp",
    "description": "Weclapp api via laravel eloquent",
    "license": "MIT",
    "keywords": ["laravel", "accounting"],
    "authors": [
        {
            "name": "Gecco Media GmbH",
            "email": "technik@geccomedia.de"
        }
    ],
    "require": {
        "php": ">=8.2",
        "illuminate/support": "^11|^12|^13"
    },

    "require-dev": {
        "orchestra/testbench": "^9|^10|^11",
        "larastan/larastan": "^3.0",
        "laravel/pint": "^1.0"
    },

    "autoload": {
        "psr-4": {
            "Geccomedia\\Weclapp\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "Geccomedia\\Weclapp\\Tests\\": "tests/"
        }
    },

    "extra": {
        "laravel": {
            "providers": [
                "Geccomedia\\Weclapp\\ServiceProvider"
            ]
        }
    },

    "scripts": {
        "test": "vendor/bin/phpunit",
        "analyse": "vendor/bin/phpstan analyse",
        "lint": "vendor/bin/pint",
        "lint:check": "vendor/bin/pint --test",
        "coverage": "php scripts/swagger-coverage"
    }
}
